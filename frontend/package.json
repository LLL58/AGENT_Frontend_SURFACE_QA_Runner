{
  "name": "surface-qa-agent-runner",
  "version": "1.0.0",
  "description": "前端表层 Bug 自动巡检工具 - Agent-first Frontend Surface QA Runner",
  "type": "module",
  "scripts": {
    "surface:install": "npx playwright install",
    "surface:agent": "tsx tests/surface/run-agent-surface-check.ts",
    "surface:agent:ci": "tsx tests/surface/run-agent-surface-check.ts --ci",
    "surface:health": "tsx tests/surface/run-agent-surface-check.ts --health-only",
    "surface:route": "tsx tests/surface/run-agent-surface-check.ts --route",
    "surface:debug": "tsx tests/surface/run-agent-surface-check.ts --headed --debug",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.10.0",
    "dotenv": "^16.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "playwright",
    "qa",
    "testing",
    "agent",
    "frontend",
    "surface"
  ],
  "author": "AGENT Team",
  "license": "MIT"
}
