# 目标应用配置
E2E_BASE_URL=http://localhost:3000

# 认证配置（login-form 模式）
E2E_USERNAME=test_user@example.com
E2E_PASSWORD=your_password_here

# 输出配置
AGENT_FEEDBACK_DIR=.agent-feedback

# 浏览器配置
SURFACE_HEADLESS=true
SURFACE_BROWSER=chromium
SURFACE_VIEWPORT_WIDTH=1280
SURFACE_VIEWPORT_HEIGHT=720

# 扫描配置
SURFACE_MAX_ROUTES=10
SURFACE_MAX_CONTROLS=20

# 超时配置（毫秒）
SURFACE_ACTION_TIMEOUT=10000
SURFACE_NAVIGATION_TIMEOUT=30000
SURFACE_PAGE_TIMEOUT=60000

# 失败级别配置
SURFACE_FAIL_ON=error
